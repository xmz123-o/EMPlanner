{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug main",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/main",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {"name": "LD_LIBRARY_PATH", "value": "/usr/local/lib"}
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {"text": "-enable-pretty-printing"}
            ]
        }
    ]
}